# OpenStates API configuration
OPENSTATES_API_KEY=your_openstates_api_key_here
OPENSTATES_URL=https://v3.openstates.org
QUERY_LIMIT=10

# NewsAPI configuration
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_QUERY_LIMIT=100

# Twitter/X API configuration (optional, future integration)
X_API_KEY=your_twitter_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000
